{
  "name": "@trackx/worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "BullMQ worker placeholder for TrackX background jobs.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "pnpm --filter @trackx/config build && tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm --filter @trackx/config build && vitest run",
    "typecheck": "pnpm --filter @trackx/config build && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@trackx/config": "workspace:*",
    "bullmq": "^5.61.0",
    "dotenv": "^17.2.3"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.20.5",
    "vitest": "^4.0.0"
  }
}
