{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "API_BASE_URL",
    "API_PORT",
    "BOT_PORT",
    "DATABASE_URL",
    "DEFAULT_CURRENCY",
    "DEFAULT_TIMEZONE",
    "DIRECT_URL",
    "NEXT_PUBLIC_SITE_URL",
    "NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY",
    "NEXT_PUBLIC_SUPABASE_URL",
    "OPENAI_API_KEY",
    "OPENAI_MODEL",
    "PARSER_BASE_URL",
    "PARSER_PORT",
    "REDIS_URL",
    "SUPABASE_JWKS_URL",
    "SUPABASE_SECRET_KEY",
    "TRACKX_API_SECRET",
    "TELEGRAM_ALLOWED_USER_IDS",
    "TELEGRAM_BOT_TOKEN",
    "WEB_API_BASE_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "lint": {
      "outputs": []
    }
  }
}
