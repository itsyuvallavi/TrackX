// Owner: packages/db. Prisma schema for TrackX persistent data.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Currency {
  EUR
  USD
  ILS
}

enum TransactionType {
  expense
  income
  transfer
  refund
}

enum CategoryKind {
  expense
  income
}

enum BudgetPeriod {
  week
  month
}

enum TransactionSource {
  telegram
  manual
  import
}

enum ParseStatus {
  success
  clarification
  failure
}

enum PendingClarificationStatus {
  active
  resolved
}

model User {
  id                    String                 @id @default(uuid()) @db.Uuid
  telegramUserId        String?                @unique
  email                 String?                @unique
  defaultCurrency       Currency               @default(EUR)
  timezone              String                 @default("Europe/Lisbon")
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  budgets               Budget[]
  parseEvents           ParseEvent[]
  pendingClarifications PendingClarification[]
  transactions          Transaction[]

  @@map("users")
}

model Category {
  id               String        @id @default(uuid()) @db.Uuid
  name             String        @unique
  kind             CategoryKind
  parentCategoryId String?       @db.Uuid
  isDefault        Boolean       @default(false)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  budgets          Budget[]
  parentCategory   Category?     @relation("CategoryChildren", fields: [parentCategoryId], references: [id])
  childCategories  Category[]    @relation("CategoryChildren")
  transactions     Transaction[]

  @@index([kind])
  @@map("categories")
}

model Transaction {
  id              String            @id @default(uuid()) @db.Uuid
  userId          String            @db.Uuid
  type            TransactionType
  amount          Decimal           @db.Decimal(12, 2)
  currency        Currency
  amountEur       Decimal?          @db.Decimal(12, 2)
  amountUsd       Decimal?          @db.Decimal(12, 2)
  categoryId      String            @db.Uuid
  description     String
  merchant        String?
  source          TransactionSource
  rawMessage      String?
  transactionDate DateTime
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  deletedAt       DateTime?
  category        Category          @relation(fields: [categoryId], references: [id])
  user            User              @relation(fields: [userId], references: [id])

  @@index([userId, transactionDate])
  @@index([categoryId, transactionDate])
  @@index([deletedAt])
  @@map("transactions")
}

model Budget {
  id          String       @id @default(uuid()) @db.Uuid
  userId      String       @db.Uuid
  categoryId  String       @db.Uuid
  period      BudgetPeriod
  limitAmount Decimal      @db.Decimal(12, 2)
  currency    Currency
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  category    Category     @relation(fields: [categoryId], references: [id])
  user        User         @relation(fields: [userId], references: [id])

  @@unique([userId, categoryId, period])
  @@index([userId, period, isActive])
  @@map("budgets")
}

model ExchangeRate {
  id            String   @id @default(uuid()) @db.Uuid
  baseCurrency  Currency
  quoteCurrency Currency
  rate          Decimal  @db.Decimal(18, 8)
  source        String
  date          DateTime
  createdAt     DateTime @default(now())

  @@unique([baseCurrency, quoteCurrency, date, source])
  @@index([date])
  @@map("exchange_rates")
}

model ParseEvent {
  id             String      @id @default(uuid()) @db.Uuid
  userId         String      @db.Uuid
  rawMessage     String
  parserResponse Json
  status         ParseStatus
  createdAt      DateTime    @default(now())
  user           User        @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([status])
  @@map("parse_events")
}

model PendingClarification {
  id                 String                     @id @default(uuid()) @db.Uuid
  userId             String                     @db.Uuid
  telegramUserId     String?
  originalMessage    String
  clarifyingQuestion String?
  status             PendingClarificationStatus @default(active)
  expiresAt          DateTime
  resolvedAt         DateTime?
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  user               User                       @relation(fields: [userId], references: [id])

  @@index([userId, status, expiresAt])
  @@index([telegramUserId, status])
  @@map("pending_clarifications")
}
