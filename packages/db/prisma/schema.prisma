// Owner: packages/db. Prisma schema for TrackX persistent data.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Currency {
  EUR
  USD
  ILS
}

enum TransactionType {
  expense
  income
  transfer
  refund
}

enum CategoryKind {
  expense
  income
}

enum BudgetPeriod {
  week
  month
}

enum TransactionSource {
  telegram
  manual
  import
}

enum ParseStatus {
  success
  clarification
  failure
}

enum PendingClarificationStatus {
  active
  resolved
}

enum MessageEventStatus {
  ok
  ignored
  failed
}

enum MerchantCategoryRuleSource {
  manual
  telegram_correction
  import_correction
}

enum AuthProvider {
  supabase
  neon
}

model User {
  id                    String                 @id @default(uuid()) @db.Uuid
  telegramUserId        String?                @unique
  email                 String?                @unique
  defaultCurrency       Currency               @default(EUR)
  timezone              String                 @default("Europe/Lisbon")
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  authIdentities        AuthIdentity[]
  budgets               Budget[]
  merchantCategoryRules MerchantCategoryRule[]
  messageEvents         MessageEvent[]
  parseEvents           ParseEvent[]
  pendingClarifications PendingClarification[]
  shortcutImportTokens  ShortcutImportToken[]
  telegramLinkCodes     TelegramLinkCode[]
  transactions          Transaction[]

  @@map("users")
}

model AuthIdentity {
  id             String       @id @default(uuid()) @db.Uuid
  userId         String       @db.Uuid
  provider       AuthProvider
  providerUserId String
  email          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId, provider])
  @@map("auth_identities")
}

model Category {
  id               String        @id @default(uuid()) @db.Uuid
  name             String        @unique
  kind             CategoryKind
  parentCategoryId String?       @db.Uuid
  isDefault        Boolean       @default(false)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  budgets          Budget[]
  merchantRules    MerchantCategoryRule[]
  parentCategory   Category?     @relation("CategoryChildren", fields: [parentCategoryId], references: [id])
  childCategories  Category[]    @relation("CategoryChildren")
  transactions     Transaction[]

  @@index([kind])
  @@map("categories")
}

model Transaction {
  id              String            @id @default(uuid()) @db.Uuid
  userId          String            @db.Uuid
  type            TransactionType
  amount          Decimal           @db.Decimal(12, 2)
  currency        Currency
  amountEur       Decimal?          @db.Decimal(12, 2)
  amountUsd       Decimal?          @db.Decimal(12, 2)
  categoryId      String            @db.Uuid
  description     String
  merchant        String?
  source          TransactionSource
  rawMessage      String?
  transactionDate DateTime
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  deletedAt       DateTime?
  category        Category          @relation(fields: [categoryId], references: [id])
  user            User              @relation(fields: [userId], references: [id])

  @@index([userId, transactionDate])
  @@index([categoryId, transactionDate])
  @@index([deletedAt])
  @@map("transactions")
}

model Budget {
  id          String       @id @default(uuid()) @db.Uuid
  userId      String       @db.Uuid
  categoryId  String       @db.Uuid
  period      BudgetPeriod
  limitAmount Decimal      @db.Decimal(12, 2)
  currency    Currency
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  category    Category     @relation(fields: [categoryId], references: [id])
  user        User         @relation(fields: [userId], references: [id])

  @@unique([userId, categoryId, period])
  @@index([userId, period, isActive])
  @@map("budgets")
}

model ExchangeRate {
  id            String   @id @default(uuid()) @db.Uuid
  baseCurrency  Currency
  quoteCurrency Currency
  rate          Decimal  @db.Decimal(18, 8)
  source        String
  date          DateTime
  createdAt     DateTime @default(now())

  @@unique([baseCurrency, quoteCurrency, date, source])
  @@index([date])
  @@map("exchange_rates")
}

model ParseEvent {
  id             String      @id @default(uuid()) @db.Uuid
  userId         String      @db.Uuid
  rawMessage     String
  parserResponse Json
  status         ParseStatus
  createdAt      DateTime    @default(now())
  user           User        @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([status])
  @@map("parse_events")
}

model MessageEvent {
  id                String             @id @default(uuid()) @db.Uuid
  correlationId     String
  source            String
  eventType         String
  status            MessageEventStatus
  userId            String?            @db.Uuid
  telegramUserId    String?
  telegramMessageId String?
  rawMessagePreview String?
  metadata          Json?
  errorMessage      String?
  createdAt         DateTime           @default(now())
  user              User?              @relation(fields: [userId], references: [id])

  @@index([correlationId, createdAt])
  @@index([userId, createdAt])
  @@index([telegramUserId, createdAt])
  @@index([eventType, createdAt])
  @@index([status, createdAt])
  @@map("message_events")
}

model PendingClarification {
  id                 String                     @id @default(uuid()) @db.Uuid
  userId             String                     @db.Uuid
  telegramUserId     String?
  originalMessage    String
  clarifyingQuestion String?
  status             PendingClarificationStatus @default(active)
  expiresAt          DateTime
  resolvedAt         DateTime?
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  user               User                       @relation(fields: [userId], references: [id])

  @@index([userId, status, expiresAt])
  @@index([telegramUserId, status])
  @@map("pending_clarifications")
}

model TelegramLinkCode {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @db.Uuid
  codeHash       String
  expiresAt      DateTime
  consumedAt     DateTime?
  telegramUserId String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id])

  @@index([codeHash, consumedAt, expiresAt])
  @@index([userId, consumedAt])
  @@map("telegram_link_codes")
}

model ShortcutImportToken {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @db.Uuid
  label        String
  tokenHash    String    @unique
  tokenPreview String
  lastUsedAt   DateTime?
  revokedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id])

  @@index([userId, revokedAt])
  @@map("shortcut_import_tokens")
}

model MerchantCategoryRule {
  id                 String                     @id @default(uuid()) @db.Uuid
  userId             String                     @db.Uuid
  categoryId         String                     @db.Uuid
  merchantPattern    String
  normalizedMerchant String
  source             MerchantCategoryRuleSource @default(manual)
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  category           Category                   @relation(fields: [categoryId], references: [id])
  user               User                       @relation(fields: [userId], references: [id])

  @@unique([userId, normalizedMerchant])
  @@index([userId, categoryId])
  @@map("merchant_category_rules")
}
