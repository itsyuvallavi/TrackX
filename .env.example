# Copy to .env for local development:
#   cp .env.example .env
#
# Parsed by @trackx/config unless noted otherwise.
# Docker stack secrets use TRACKX_* shell exports — see docs/local-development.md.

# Database (Postgres)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/trackx"

# Redis (BullMQ worker queue backend)
REDIS_URL="redis://localhost:6379"

# Parser (OpenAI structured output)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
PARSER_PORT="4002"
PARSER_BASE_URL="http://localhost:4002"

# API (main backend)
API_PORT="4001"
API_BASE_URL="http://localhost:4001"

# Telegram bot
TELEGRAM_BOT_TOKEN=""
TELEGRAM_ALLOWED_USER_IDS=""
BOT_PORT="4003"

# Web dashboard (read directly by apps/web, not @trackx/config)
WEB_API_BASE_URL="http://localhost:4001"

# Worker (WORKER_ENABLE_SCHEDULES read directly by services/worker)
WORKER_ENABLE_SCHEDULES="false"

# Defaults
DEFAULT_TIMEZONE="Europe/Lisbon"
DEFAULT_CURRENCY="EUR"
